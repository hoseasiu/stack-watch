---
layout: base.njk
title: Frameworks
nav: tech
permalink: "tech/index.html"
---
<div class="section-header">
  <div class="section-title">Framework adoption ({{ frameworks.length }})</div>
</div>

{% if frameworks.length %}
<div class="table-wrap">
<table class="org-table">
  <thead>
    <tr>
      <th scope="col">Framework</th>
      <th scope="col" style="width:120px">Orgs detected</th>
    </tr>
  </thead>
  <tbody>
    {% for fw in frameworks %}
    <tr>
      <td class="org-name"><a href="{{ ('/tech/' + fw.slug + '/') | url }}">{{ fw.slug }}</a></td>
      <td><span class="signal-count">{{ fw.count }}</span></td>
    </tr>
    {% endfor %}
  </tbody>
</table>
</div>
{% else %}
  <div class="empty-state">No framework signals detected yet.</div>
{% endif %}
