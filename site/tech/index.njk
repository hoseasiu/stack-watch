---
layout: base.njk
title: Frameworks
nav: tech
permalink: "tech/index.html"
---
<div class="section-header">
  <div class="section-title">Framework adoption ({{ frameworks.length }})</div>
</div>

{% if frameworks.length %}
<table class="org-table">
  <thead>
    <tr>
      <th>Framework</th>
      <th style="width:120px">Orgs detected</th>
    </tr>
  </thead>
  <tbody>
    {% for fw in frameworks %}
    <tr>
      <td class="org-name">{{ fw.slug }}</td>
      <td><span class="signal-count">{{ fw.count }}</span></td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
  <div class="empty-state">No framework signals detected yet.</div>
{% endif %}

<p style="color:var(--text3);font-size:12px;margin-top:1rem">
  Per-framework adoption-over-time pages ship in a later phase — see
  <a href="{{ '/methodology/' | url }}">methodology</a> for the current data collection status.
</p>
