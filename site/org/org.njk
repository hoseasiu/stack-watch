---
layout: base.njk
nav: orgs
pagination:
  data: orgs
  size: 1
  alias: org
permalink: "org/{{ org.slug }}/"
eleventyComputed:
  title: "{{ org.display_name }}"
---
<div class="org-header">
  <div class="org-title">{{ org.display_name }}</div>
  <span class="org-sector-badge">{{ org.sector }}</span>
</div>
<div class="org-meta">
  github.com/{{ org.github_org }} · first detected {{ org.first_detected }} · last updated {{ org.last_updated }} · {{ org.signal_count }} signals
</div>

<div class="section-header">
  <div class="section-title">Frameworks</div>
</div>

{% if org.frameworks | length %}
  {% for slug, fw in org.frameworks %}
  <div class="evidence-card">
    <div class="evidence-card-header">
      <span class="evidence-card-title">{{ slug }}</span>
      <span class="confidence-label"><span class="confidence-dot {{ fw.confidence }}"></span>{{ fw.confidence }} confidence</span>
    </div>
    {% for e in fw.evidence %}
    <div class="evidence-item">
      {{ e.type | replace("_", " ") }} · {{ e.repo }}{% if e.file %} · {{ e.file }}{% endif %} ·
      <a href="{{ e.url }}" target="_blank" rel="noopener">view source →<span class="sr-only"> (opens in new tab)</span></a>
    </div>
    {% endfor %}
  </div>
  {% endfor %}
{% else %}
  <div class="empty-state">No framework dependency signals detected yet.</div>
{% endif %}

<div class="section-header">
  <div class="section-title">Model providers</div>
</div>

{% if org.model_providers | length %}
  {% for slug, mp in org.model_providers %}
  <div class="evidence-card">
    <div class="evidence-card-header">
      <span class="evidence-card-title">{{ slug }}</span>
      <span class="confidence-label"><span class="confidence-dot {{ mp.confidence }}"></span>{{ mp.confidence }} confidence</span>
    </div>
    {% for e in mp.evidence %}
    <div class="evidence-item">
      {{ e.type | replace("_", " ") }} · {{ e.repo }}{% if e.file %} · {{ e.file }}{% endif %} ·
      <a href="{{ e.url }}" target="_blank" rel="noopener">view source →<span class="sr-only"> (opens in new tab)</span></a>
    </div>
    {% endfor %}
  </div>
  {% endfor %}
{% else %}
  <div class="empty-state">No model provider signals detected yet.</div>
{% endif %}

{% if org.agent_config %}
<div class="section-header">
  <div class="section-title">Agent config files</div>
</div>
<div class="evidence-card">
  <div class="evidence-card-header">
    <span class="evidence-card-title">CLAUDE.md / AGENTS.md</span>
    <span class="confidence-label"><span class="confidence-dot {{ org.agent_config.confidence }}"></span>{{ org.agent_config.confidence }} confidence</span>
  </div>
  {% for e in org.agent_config.evidence %}
  <div class="evidence-item">
    {{ e.repo }} · {{ e.file }} ·
    <a href="{{ e.url }}" target="_blank" rel="noopener">view source →</a>
  </div>
  {% endfor %}
</div>
{% endif %}

<div class="section-header">
  <div class="section-title">Job signals</div>
</div>

{% if org.job_signals | length %}
  {% for j in org.job_signals %}
  <div class="evidence-card">
    <div class="evidence-card-header">
      <span class="evidence-card-title">{{ j.title }}</span>
      <span class="confidence-label"><span class="confidence-dot medium"></span>medium confidence</span>
    </div>
    <div class="evidence-item">
      terms matched: {{ j.terms_matched | join(", ") }} · posted {{ j.posted }} ·
      <a href="{{ j.url }}" target="_blank" rel="noopener">view posting →<span class="sr-only"> (opens in new tab)</span></a>
    </div>
  </div>
  {% endfor %}
{% else %}
  <div class="empty-state">No job posting signals detected yet.</div>
{% endif %}

<div class="section-header">
  <div class="section-title">HuggingFace models</div>
</div>

{% if org.hf_models | length %}
  {% for m in org.hf_models %}
  <div class="evidence-card">{{ m.name }}</div>
  {% endfor %}
{% else %}
  <div class="empty-state">No HuggingFace model card signals detected yet.</div>
{% endif %}
