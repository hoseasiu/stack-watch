---
layout: base.njk
nav: tech
pagination:
  data: frameworkDetails
  size: 1
  alias: fw
permalink: "tech/{{ fw.slug }}/"
eleventyComputed:
  title: "{{ fw.slug }}"
---
<div class="org-header">
  <div class="org-title">{{ fw.slug }}</div>
</div>
<div class="org-meta">
  {{ fw.org_count }} organization{% if fw.org_count != 1 %}s{% endif %} detected · signals inferred from public dependency files only
</div>

<div class="section-header">
  <div class="section-title">Adoption over time</div>
</div>

{% if fw.monthly | length %}
<div class="table-wrap" style="padding:1rem">
  <svg viewBox="0 0 {{ fw.monthly.length * 40 }} 120" width="100%" height="120" role="img" aria-label="Monthly signal count for {{ fw.slug }}">
    {% for m in fw.monthly %}
    {% set barHeight = (m.count / fw.monthly_max * 80) if fw.monthly_max else 0 %}
    <rect x="{{ loop.index0 * 40 + 8 }}" y="{{ 90 - barHeight }}" width="24" height="{{ barHeight }}" fill="var(--accent, #C4793A)"></rect>
    <text x="{{ loop.index0 * 40 + 20 }}" y="106" font-size="10" text-anchor="middle" fill="var(--text3, #A09488)">{{ m.month }}</text>
    <text x="{{ loop.index0 * 40 + 20 }}" y="{{ 90 - barHeight - 4 if barHeight > 0 else 86 }}" font-size="10" text-anchor="middle" fill="var(--text2, #6B6358)">{{ m.count }}</text>
    {% endfor %}
  </svg>
</div>
{% else %}
  <div class="empty-state">No signal history yet.</div>
{% endif %}

<div class="section-header">
  <div class="section-title">Organizations</div>
</div>

{% if fw.orgs | length %}
<div class="table-wrap">
<table class="org-table">
  <thead>
    <tr>
      <th scope="col">Organization</th>
      <th scope="col" style="width:140px">Confidence</th>
      <th scope="col" style="width:140px">First seen</th>
    </tr>
  </thead>
  <tbody>
    {% for o in fw.orgs %}
    <tr>
      <td class="org-name"><a href="{{ ('/org/' + o.slug + '/') | url }}">{{ o.display_name }}</a></td>
      <td><span class="confidence-label"><span class="confidence-dot {{ o.confidence }}"></span>{{ o.confidence }}</span></td>
      <td><span class="signal-count">{{ o.first_seen }}</span></td>
    </tr>
    {% endfor %}
  </tbody>
</table>
</div>
{% else %}
  <div class="empty-state">No organizations detected yet.</div>
{% endif %}
